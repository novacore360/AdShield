<?xml version="1.0" encoding="utf-8"?>
<!-- Prevents Android auto-backup / device-transfer from copying our local
     detection database and encrypted prefs off this device. -->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapability="true">
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
